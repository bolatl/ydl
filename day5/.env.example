# Course-issued model API (OpenAI-compatible). Copy to .env and fill in.
# .env is gitignored — never commit real keys.

# Chat model (gemma4)
LLM_BASE_URL=https://llm.alem.ai/v1
LLM_API_KEY=
LLM_MODEL=gemma4

# Embedding model. On this provider it's a SEPARATE key/model from chat.
# (If your API serves embeddings under the chat key, reuse the same values.)
EMBEDDING_BASE_URL=https://llm.alem.ai/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-1024

# Phase 3 (optional email summary) — use your OWN email as the "admin".
# Do NOT reuse the MailerSend key printed in the course PDF.
ADMIN_EMAIL=
MAILERSEND_API_KEY=
# Sender must be on a MailerSend-verified domain. Trial accounts get a sandbox
# domain like MS_xxxx@trial-yyy.mlsender.net (find it in the MailerSend dashboard).
# Note: the API token and the sender domain must belong to the SAME MailerSend account.
MAILERSEND_FROM_EMAIL=
MAILERSEND_FROM_NAME=Грант-помощник фонда Есенова

# Phase 4 (optional Telegram bot) — token from @BotFather. Run: python bot.py
TELEGRAM_BOT_TOKEN=
